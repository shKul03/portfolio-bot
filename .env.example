# PostgreSQL connection string (required)
DATABASE_URL=postgresql://portfoliobot:portfoliobot@localhost:5432/portfoliobot

# Postgres credentials (used by docker-compose)
POSTGRES_USER=portfoliobot
POSTGRES_PASSWORD=portfoliobot
POSTGRES_DB=portfoliobot

# Groq API key — required when LLM_PROVIDER=groq
GROQ_API_KEY=

# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Embedding model served by Ollama
EMBEDDING_MODEL=nomic-embed-text

# LLM provider: groq (dev) or ollama (prod)
LLM_PROVIDER=groq

# API key protecting all /ingest endpoints (required)
INGEST_API_KEY=

# Comma-separated list of allowed CORS origins — never use *
ALLOWED_ORIGINS=http://localhost:3000

# RAG retrieval settings
TOP_K=5
MIN_SCORE=0.42
CHUNK_SIZE=700
CHUNK_OVERLAP=100
