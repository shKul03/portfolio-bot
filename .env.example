# PostgreSQL connection string (required)
DATABASE_URL=postgresql://portfoliobot:portfoliobot@localhost:5432/portfoliobot

# Postgres credentials (used by docker-compose)
POSTGRES_USER=portfoliobot
POSTGRES_PASSWORD=portfoliobot
POSTGRES_DB=portfoliobot

# Groq API key — LLM generation (llama-3.3-70b-versatile). Free at console.groq.com
GROQ_API_KEY=

# Nomic AI API key — embeddings (nomic-embed-text-v1.5, 768 dims). Free at atlas.nomic.ai
NOMIC_API_KEY=

# API key protecting all /ingest endpoints (required)
INGEST_API_KEY=

# Comma-separated list of allowed CORS origins — never use *
ALLOWED_ORIGINS=http://localhost:3000

# RAG retrieval settings
TOP_K=5
MIN_SCORE=0.42
CHUNK_SIZE=400
CHUNK_OVERLAP=50
